-- ===== SERVER FINDER (FIX 773) =====
local function getServer()
    local url = "https://games.roblox.com/v1/games/"..PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
    local body = HttpService:JSONDecode(game:HttpGet(url))

    local bestServer, lowest = nil, math.huge

    for _,v in pairs(body.data) do
        if v.playing < TARGET_PLAYERS
        and v.playing < v.maxPlayers
        and not visitedServers[v.id]
        and v.id ~= game.JobId -- tránh join lại
        and not v.accessCode then -- tránh server private

            if v.playing < lowest then
                lowest = v.playing
                bestServer = v
            end
        end
    end

    if bestServer then
        visitedServers[bestServer.id] = true
        return bestServer.id
    end
end

-- ===== HOP FUNCTION (FIX LOGIC RETRY) =====
local function hopServer()
    if hopping or not AUTO_ENABLED then return end
    hopping = true

    local MAX_RETRY = 5

    while AUTO_ENABLED do
        local serverId = getServer()

        if serverId then
            local success = false

            for i = 1, MAX_RETRY do
                if not AUTO_ENABLED then break end

                task.wait(math.random(1,2)) -- anti spam teleport

                success = pcall(function()
                    TeleportService:TeleportToPlaceInstance(PlaceId, serverId, LocalPlayer)
                end)

                if success then
                    task.wait(6)
                    break
                else
                    visitedServers[serverId] = true
                    serverId = getServer() -- đổi server mới
                    task.wait(2)
                end
            end
        else
            task.wait(4)
        end

        task.wait(1)
    end

    hopping = false
end

