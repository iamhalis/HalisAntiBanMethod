corner.CornerRadius = UDim.new(0,8)

--// Server hop
local function ServerHop()
    local success, result = pcall(function()
        local req = game:HttpGet(
            "https://games.roblox.com/v1/games/"..PLACE_ID.."/servers/Public?sortOrder=Asc&limit=100"
        )
        return HttpService:JSONDecode(req)
    end)
    if not success or not result then return end

    local bestServer, lowestPlayers = nil, math.huge

    for _, v in pairs(result.data) do
        if v.id ~= game.JobId
        and v.playing < v.maxPlayers
        and v.playing <= MAX_PLAYERS_ALLOWED then
            if v.playing < lowestPlayers then
                lowestPlayers = v.playing
                bestServer = v.id
            end
        end
    end

    if bestServer then
        TeleportService:TeleportToPlaceInstance(PLACE_ID, bestServer, LocalPlayer)
    end
end

--// Toggle
ToggleBtn.MouseButton1Click:Connect(function()
    if not scriptRunning then return end
    autoHop = not autoHop

    if autoHop then
        ToggleBtn.Text = "ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,0)
        timeLeft = hopDelay
        TopCountdown.Visible = true
    else
        ToggleBtn.Text = "OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(170,0,0)
        TopCountdown.Visible = false
    end
end)

--// Time update
TimeBox.FocusLost:Connect(function()
    local num = tonumber(TimeBox.Text)
    if num and num > 0 then
        hopDelay = num
        timeLeft = hopDelay
    else
        TimeBox.Text = tostring(hopDelay)
    end
end)

--// Stop
StopBtn.MouseButton1Click:Connect(function()
    scriptRunning = false
    autoHop = false
    ScreenGui:Destroy()
end)

--// Loop
task.spawn(function()
    while scriptRunning do
        task.wait(1)

        if autoHop then
            timeLeft -= 1
            TopCountdown.Text = "Next hop: "..timeLeft.."s"

            if timeLeft <= 0 then
                timeLeft = hopDelay
                ServerHop()
            end
        end
    end
end)
