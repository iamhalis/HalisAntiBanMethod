-- ===== AUTO LOOP =====
task.spawn(function()
    local timer = HOP_INTERVAL

    while true do
        if AUTO_ENABLED then
            countdown.Text = "Next hop in: "..timer.."s"
            timer -= 1

            if timer <= 0 then
                hopServer()
                timer = HOP_INTERVAL
            end
        else
            countdown.Text = "Auto hop paused"
        end

        task.wait(1)
    end
end)
